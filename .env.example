# GitHub Gist cloud sync (optional — app works fully offline without these)
#
# Step 1 — Create a secret Gist:
#   https://gist.github.com
#   Filename: everyday-habits.json   Content: []
#   Copy the ID from the URL (the long hex string at the end)
#
# Step 2 — Create a Personal Access Token with the "gist" scope:
#   https://github.com/settings/tokens/new?scopes=gist
#   Copy the token (starts with ghp_...)
#
VITE_GIST_ID=your_gist_id_here
VITE_GITHUB_TOKEN=ghp_your_token_here
